PORT=4001
# Bind address: 0.0.0.0 = reachable from phone on same Wi-Fi (LAN).
# Use 127.0.0.1 only if you never need the phone to call this host.
HOST=0.0.0.0
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/sleep-lock
# Comma-separated allowed browser origins (Expo web may use 8081 or 8082).
CORS_ORIGIN=http://localhost:8081,http://localhost:8082,http://127.0.0.1:8081,http://127.0.0.1:8082
# Leave false/unset. Only set true if you deliberately expose beyond the LAN.
ALLOW_PUBLIC=false
# JWT for /auth/signup|/login|/me (change in any non-dev deploy).
JWT_SECRET=sleep-lock-dev-secret-change-me
JWT_EXPIRES_IN=30d
