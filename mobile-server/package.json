{
  "name": "mobile-server",
  "version": "1.0.0",
  "description": "Phase 2 Sleep Lock API — Express + MongoDB (separate from Phase 1 SQLite)",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:health": "curl -sf http://localhost:4001/api/health",
    "test:schemas": "npx tsx scripts/check-schemas.mjs",
    "test:sessions": "npx tsx scripts/check-sessions-api.mjs",
    "test:schedule": "npx tsx scripts/check-schedule-api.mjs",
    "test:lock-schedule": "npx tsx scripts/check-lock-schedule.mjs",
    "test:schedule-change": "npx tsx scripts/check-schedule-change.mjs",
    "test:monthly-stats": "npx tsx scripts/check-monthly-stats.mjs",
    "test:comparison": "npx tsx scripts/check-comparison.mjs",
    "test:improvement-verdict": "npx tsx scripts/check-improvement-verdict.mjs",
    "test:phase1-export": "npx tsx scripts/check-phase1-export.mjs",
    "test:lan-only": "npx tsx scripts/check-lan-only.mjs",
    "test:home-location": "npx tsx scripts/check-home-location.mjs",
    "test:lock-session": "npx tsx scripts/check-lock-session.mjs",
    "test:auth": "npx tsx scripts/check-auth.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
